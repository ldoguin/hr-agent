# Render Environment Variables Template
# Copy this file to .env.render and fill in your secret values
# Then upload to Render dashboard under your service's Environment section

# =============================================================================
# App Configuration
# =============================================================================
API_USERNAME=ubuntu
API_PASSWORD=debian
API_SECRET_KEY=your-secret-key-here-change-in-production
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=5256000000

# =============================================================================
# Couchbase Root Certificate (Choose ONE option)
# =============================================================================

# Option A: Path to secret file (recommended for Render)
# Upload the certificate as a secret file in Render dashboard
# It will be mounted at /etc/secrets/couchbase-root-cert.pem
CB_ROOT_CERTIFICATE_PATH=/etc/secrets/couchbase-root-cert.pem

# Option B: Base64-encoded certificate (alternative)
# Generate with: cat burgundydavidluckham-root-certificate.txt | base64 -w 0
# Then paste the output here (single line, no newlines)
# CB_ROOT_CERTIFICATE_B64=LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0tLi4u

# =============================================================================
# Couchbase Configuration
# =============================================================================
CB_CONN_STRING=couchbases://your-cluster.cloud.couchbase.com
CB_USERNAME=your-username
CB_PASSWORD=your-password
CB_BUCKET=hrdemo
CB_SCOPE=agentc_data
CB_COLLECTION=candidates
CB_INDEX=candidates_index

# =============================================================================
# Capella AI Configuration (Primary)
# =============================================================================
CAPELLA_API_ENDPOINT=https://your-endpoint.ai.cloud.couchbase.com
CAPELLA_API_LLM_KEY=your-llm-api-key
CAPELLA_API_LLM_MODEL=deepseek-ai/deepseek-r1-distill-llama-8b
CAPELLA_API_EMBEDDINGS_KEY=your-embeddings-api-key
CAPELLA_API_EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# =============================================================================
# OpenAI Configuration (Fallback)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# =============================================================================
# Agent Catalog Configuration
# =============================================================================
AGENT_CATALOG_CONN_STRING=couchbases://your-cluster.cloud.couchbase.com
AGENT_CATALOG_USERNAME=your-username
AGENT_CATALOG_PASSWORD=your-password
AGENT_CATALOG_BUCKET=agentc

# =============================================================================
# AgentMail Configuration
# =============================================================================
AGENTMAIL_API_KEY=your-agentmail-api-key

# =============================================================================
# Ngrok Configuration (for webhooks)
# =============================================================================
NGROK_AUTHTOKEN=your-ngrok-authtoken
WEBHOOK_DOMAIN=your-domain.ngrok-free.app
INBOX_USERNAME=hrbot

# =============================================================================
# Other Configuration
# =============================================================================
TOKENIZERS_PARALLELISM=false
BAMBOOHR_API_KEY=your-bamboohr-api-key
